    // Serialize instruction data
    const instructionData = Buffer.concat([
      UPDATE_DISCRIMINATOR,
      serializeUpdateParams(TEST_MINT_PRICE, TEST_TARGET_XNT)
    ]);
    
    // Create instruction
    const instruction = new TransactionInstruction({
      programId: PROGRAM_ID,
